#!/usr/bin/env node
// devloop CLI dispatcher (ESM — the package is type:module). Forwards to the shipped dist
// CLIs so colleagues need only Node (no build, no tsx). The skills call dist/cli/*.js
// directly; this is the ergonomic human entry (e.g. `devloop init <repo>`).
import { spawnSync } from "node:child_process";
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";

const root = dirname(fileURLToPath(import.meta.url));
const ALLOWED = [
  "init",
  "check-guardians",
  "derive-tier",
  "next-action",
  "precondition-check",
  "verify-review",
  "verify-unskip",
  "cleanup",
];
const [sub, ...rest] = process.argv.slice(2);

if (!ALLOWED.includes(sub)) {
  process.stderr.write(`usage: devloop <${ALLOWED.join("|")}> [args]\n`);
  process.exit(64);
}

const target = join(root, "..", "dist", "cli", `${sub}.js`);
const result = spawnSync(process.execPath, [target, ...rest], { stdio: "inherit" });
process.exit(result.status == null ? 1 : result.status);
